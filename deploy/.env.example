# Copia este archivo a deploy/.env y define los valores. deploy/.env está en .gitignore
# (cero secretos en el repositorio). NO pongas secretos reales aquí.

# Contraseña del SA de SQL Server (debe cumplir la política de complejidad de SQL Server).
MSSQL_SA_PASSWORD=

# Clave de firma JWT compartida por Gateway + servicios (Story 6.1). HMAC-SHA256 → mínimo 32 bytes
# (256 bits). Generar una aleatoria, p. ej.: openssl rand -base64 48. NUNCA commitear la real.
JWT_SIGNING_KEY=
