# Normalización de fin de línea
* text=auto eol=lf

*.cs      text eol=lf diff=csharp
*.csproj  text eol=lf
*.sln     text eol=crlf
*.md      text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sh      text eol=lf
*.ps1     text eol=crlf
*.cmd     text eol=crlf
*.bat     text eol=crlf

# Binarios
*.png binary
*.jpg binary
*.pfx binary
*.ico binary
