        },
        {
          "name": "Cancelaciones pendientes (Agente) → 200",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{jwtAgente}}" } ],
            "url": "{{baseUrl}}/api/v1/reservas/cancelaciones-pendientes"
          },
          "event": [ { "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('cuerpo es lista', () => pm.expect(pm.response.json()).to.be.an('array'));"
          ] } } ]
        },
        {
          "name": "Resolver cancelación (Agente) → 200",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{jwtAgente}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "url": "{{baseUrl}}/api/v1/reservas/{{reservaDosPasosId}}/cancelacion/resolucion",
            "body": { "mode": "raw", "raw": "{\"decision\":1}" }
          },
          "event": [ { "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('Cancelada', () => pm.expect(pm.response.json().estado).to.eql('Cancelada'));"
          ] } } ]
        },
        {
          "name": "[neg] Resolver cancelación con rol Viajero → 403",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{jwtViajero}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "url": "{{baseUrl}}/api/v1/reservas/{{reservaId}}/cancelacion/resolucion",
            "body": { "mode": "raw", "raw": "{\"decision\":1}" }
          },
          "event": [ { "listen": "test", "script": { "exec": [ "pm.test('403 Forbidden (SoloAgente)', () => pm.response.to.have.status(403));" ] } } ]
        },
        {
          "name": "Cancelar reserva (atajo, Agente) → 200",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{jwtAgente}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "url": "{{baseUrl}}/api/v1/reservas/{{reservaId}}/cancelaciones/atajo",
            "body": { "mode": "raw", "raw": "{\"categoriaMotivo\":\"Cliente\",\"detalleMotivo\":\"newman\",\"iniciador\":2,\"decision\":1}" }
          },
          "event": [ { "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('Cancelada', () => pm.expect(pm.response.json().estado).to.eql('Cancelada'));"
          ] } } ]
        },
        {
          "name": "[neg] Detalle de reserva inexistente → 404",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{jwtAgente}}" } ],
            "url": "{{baseUrl}}/api/v1/reservas/00000000-0000-0000-0000-000000000000"
          },
          "event": [ { "listen": "test", "script": { "exec": [ "pm.test('404 Not Found', () => pm.response.to.have.status(404));" ] } } ]
        }
      ]
    }
  ]
}
