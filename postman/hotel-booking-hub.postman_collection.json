{
  "info": {
    "name": "hotel-booking-hub · API completa",
    "description": "Colección por servicio (Gateway/Health · Hoteles · Reservas) con un request por endpoint real, casos positivos que encadenan variables (rowVersion, ids) y negativos (401/403/404/409/422). JWT HS256 minteado en el pre-request (CryptoJS) para roles Agente y Viajero. Ejecutable con Newman en CI contra el docker-compose. Variables baseUrl y jwtSigningKey se pasan con --env-var.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "jwtSigningKey", "value": "" },
    { "key": "jwtAgente", "value": "" },
    { "key": "jwtViajero", "value": "" },
    { "key": "hotelId", "value": "" },
    { "key": "hotelRowVersion", "value": "" },
    { "key": "hotelRowVersionStale", "value": "" },
    { "key": "hotelDesechableId", "value": "" },
    { "key": "hotelDesechableRowVersion", "value": "" },
    { "key": "habitacionId", "value": "" },
    { "key": "habRowVersion", "value": "" },
    { "key": "reservaId", "value": "" },
    { "key": "reservaIdemId", "value": "" },
    { "key": "reservaDosPasosId", "value": "" },
    { "key": "idemKey", "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Mintea JWT HS256 con la misma clave que valida el sistema (issuer/audience de appsettings).",
          "function b64url(wordArray){ return CryptoJS.enc.Base64.stringify(wordArray).replace(/=+$/,'').replace(/\\+/g,'-').replace(/\\//g,'_'); }",
          "function mint(role, email){",
          "  var key = pm.variables.get('jwtSigningKey');",
          "  var now = Math.floor(Date.now()/1000);",
          "  var header = b64url(CryptoJS.enc.Utf8.parse(JSON.stringify({alg:'HS256',typ:'JWT'})));",
          "  var claims = {sub:email, email:email, role:role, iss:'hotel-booking-hub', aud:'hotel-booking-hub-api', iat:now, nbf:now-60, exp:now+3600};",
          "  var payload = b64url(CryptoJS.enc.Utf8.parse(JSON.stringify(claims)));",
          "  var sig = b64url(CryptoJS.HmacSHA256(header+'.'+payload, key));",
          "  return header+'.'+payload+'.'+sig;",
          "}",
          "pm.collectionVariables.set('jwtAgente', mint('Agente','agente@x.com'));",
          "pm.collectionVariables.set('jwtViajero', mint('Viajero','viajero@x.com'));",
          "if (!pm.collectionVariables.get('idemKey')) { pm.collectionVariables.set('idemKey', 'newman-' + Date.now()); }"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Gateway / Health",
      "item": [
        {
          "name": "GET /health → 200 (anónimo)",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" },
          "event": [ { "listen": "test", "script": { "exec": [ "pm.test('health 200', () => pm.response.to.have.status(200));" ] } } ]
        },
        {
          "name": "GET /alive → 200 (anónimo)",
          "request": { "method": "GET", "url": "{{baseUrl}}/alive" },
          "event": [ { "listen": "test", "script": { "exec": [ "pm.test('alive 200', () => pm.response.to.have.status(200));" ] } } ]
        },
        {
          "name": "[neg] GET /api/v1/reservas sin token → 401",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/reservas" },
          "event": [ { "listen": "test", "script": { "exec": [
            "pm.test('401 en el borde', () => pm.response.to.have.status(401));",
            "pm.test('reto Bearer', () => pm.expect(pm.response.headers.get('WWW-Authenticate') || '').to.include('Bearer'));"
          ] } } ]
        }
      ]
    },
